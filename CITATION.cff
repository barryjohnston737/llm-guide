cff-version: 1.2.0
title: "LLM Taxonomy Guide: an interactive reference for large language models"
message: "If you use this software, please cite it using the metadata from this file."
type: software
authors:
  - given-names: Barry
    family-names: Johnston
    affiliation: Atlantic Technological University
    email: barry.johnston@atu.ie
